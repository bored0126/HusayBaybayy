<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_brown">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="48dp"
                android:orientation="horizontal">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="H"
                    android:fontFamily="sans-serif-thin"
                    android:textColor="@color/logo_teal" android:textSize="56sp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="B"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="sans-serif-thin"
                    android:textColor="@color/logo_green" android:textSize="56sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-light"
                    android:text="Husay Bayba"
                    android:layout_gravity="center_vertical"
                    android:textColor="@color/logo_brown"
                    android:textSize="28sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-light"
                    android:text="y"
                    android:layout_gravity="center_vertical"
                    android:textColor="@color/logo_teal"
                    android:textSize="28sp" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnFlashPick"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_btn_about"
                android:drawableStart="@drawable/ic_game_flash_pick"
                android:drawablePadding="24dp"
                android:elevation="8dp"
                android:gravity="center_vertical|start"
                android:paddingStart="48dp"
                android:paddingEnd="24dp"
                android:text="PiliBAYBAY"
                android:textAllCaps="false"
                android:textColor="@color/btn_about_text"
                android:fontFamily="sans-serif-light"
                android:textSize="20sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnAudioGame"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_btn_about"
                android:drawableStart="@drawable/ic_game_audio"
                android:drawablePadding="24dp"
                android:elevation="8dp"
                android:gravity="center_vertical|start"
                android:paddingStart="48dp"
                android:paddingEnd="24dp"
                android:text="DinigBAYBAY"
                android:textAllCaps="false"
                android:textColor="@color/btn_about_text"
                android:fontFamily="sans-serif-light"
                android:textSize="20sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnDefinitionGame"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_btn_about"
                android:drawableStart="@drawable/ic_game_definition"
                android:drawablePadding="24dp"
                android:elevation="8dp"
                android:gravity="center_vertical|start"
                android:paddingStart="48dp"
                android:paddingEnd="24dp"
                android:text="IsipBAYBAY"
                android:textAllCaps="false"
                android:textColor="@color/btn_about_text"
                android:fontFamily="sans-serif-light"
                android:textSize="20sp" />

        </LinearLayout>
    </ScrollView>

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:padding="10dp"
        android:src="@drawable/ic_back_arrow"
        android:background="@drawable/bg_back_button"
        android:scaleType="fitCenter"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>