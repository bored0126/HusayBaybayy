<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_brown">

    <!-- Logo -->
    <LinearLayout
        android:id="@+id/llLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-thin"
            android:text="H"
            android:textColor="@color/logo_teal"
            android:textSize="48sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-thin"
            android:text="B"
            android:layout_marginEnd="8dp"
            android:textColor="@color/logo_green"
            android:textSize="48sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-light"
            android:text="Husay Bayba"
            android:layout_gravity="center_vertical"
            android:textColor="@color/logo_brown"
            android:textSize="24sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-light"
            android:text="y"
            android:layout_gravity="center_vertical"
            android:textColor="@color/logo_teal"
            android:textSize="24sp" />
    </LinearLayout>

    <!-- Title with Icon -->
    <LinearLayout
        android:id="@+id/llGameTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/llLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        
        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_game_audio"
            android:layout_marginEnd="8dp"/>
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DinigBAYBAY"
            android:textColor="@color/logo_brown"
            android:fontFamily="sans-serif-light"
            android:textSize="24sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvInstructionBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:background="@drawable/bg_dictionary_meaning"
        android:padding="32dp"
        android:text="PANUTO: Pindutin ang simbolo ng speaker at i-type ang wastong baybay mula sa narinig na tunog sa speaker"
        android:textColor="@color/logo_brown"
        android:fontFamily="sans-serif-light"
        android:textSize="18sp"
        android:textAlignment="center"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/llGameTitle"
        app:layout_constraintBottom_toTopOf="@id/btnStartAudio"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <android.widget.Button
        android:id="@+id/btnStartAudio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="180dp"
        android:layout_marginBottom="64dp"
        android:background="@drawable/bg_dictionary_word_btn"
        app:backgroundTint="@null"
        android:text="SIMULAN"
        android:textColor="@color/logo_brown"
        android:fontFamily="sans-serif-light"
        android:textSize="20sp"
        android:elevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:padding="10dp"
        android:src="@drawable/ic_back_arrow"
        android:background="@drawable/bg_back_button"
        android:scaleType="fitCenter"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>