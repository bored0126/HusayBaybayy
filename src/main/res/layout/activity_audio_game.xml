<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_brown">

    <!-- Logo Section -->
    <LinearLayout
        android:id="@+id/llLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-thin"
            android:text="H"
            android:textColor="@color/logo_teal"
            android:textSize="48sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-thin"
            android:text="B"
            android:layout_marginEnd="8dp"
            android:textColor="@color/logo_green"
            android:textSize="48sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-light"
            android:text="Husay Bayba"
            android:layout_gravity="center_vertical"
            android:textColor="@color/logo_brown"
            android:textSize="24sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-light"
            android:text="y"
            android:layout_gravity="center_vertical"
            android:textColor="@color/logo_teal"
            android:textSize="24sp" />
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/llIndicators"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/llLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.25">

        <TextView
            android:id="@+id/tvAudioCounter"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_counter_box"
            android:text="1"
            android:textColor="#222222"
            android:gravity="center"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <ImageView
            android:id="@+id/ivIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_game_audio"
            app:layout_constraintTop_toTopOf="@id/tvAudioCounter"
            app:layout_constraintBottom_toBottomOf="@id/tvAudioCounter"
            app:layout_constraintStart_toEndOf="@id/tvAudioCounter"/>
            
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="48dp"
        android:paddingEnd="48dp"
        app:layout_constraintTop_toBottomOf="@id/llIndicators"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.25">

        <LinearLayout
            android:id="@+id/btnPlayAudio"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginBottom="48dp"
            android:background="@drawable/bg_btn_about"
            android:gravity="center"
            android:orientation="horizontal"
            android:clickable="true"
            android:focusable="true">
            
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_lock_silent_mode_off"
                android:tint="@color/logo_brown" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="PINDUTIN UPANG MARINIG"
                android:textColor="@color/logo_brown"
                android:fontFamily="sans-serif-light"
                android:textSize="14sp" />
        </LinearLayout>

        <EditText
            android:id="@+id/etAnswer"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@drawable/bg_choice_blue"
            android:hint=""
            android:imeOptions="actionDone"
            android:inputType="textCapCharacters"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-light"
            android:textSize="20sp" />

        <LinearLayout
            android:id="@+id/llHintClueContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:background="@drawable/bg_dictionary_meaning"
            android:padding="16dp"
            android:visibility="gone"
            android:elevation="2dp">
            
            <TextView
                android:id="@+id/tvHintSyllables"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text=""
                android:textColor="@color/logo_brown"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp"/>
                
            <TextView
                android:id="@+id/tvHintDefinition"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text=""
                android:textColor="#5A4A42"
                android:textSize="14sp"
                android:fontFamily="sans-serif-light"/>
        </LinearLayout>

    </LinearLayout>



    <ImageButton
        android:id="@+id/btnPause"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:padding="10dp"
        android:src="@drawable/ic_pause"
        android:background="@drawable/bg_back_button"
        android:scaleType="fitCenter"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageButton
        android:id="@+id/btnHint"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:padding="10dp"
        android:src="@drawable/ic_hint"
        android:background="@drawable/bg_back_button"
        android:scaleType="fitCenter"
        android:elevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/btnPause"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>